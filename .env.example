# SNAP AI — environment variables
#
# Copy this file to `.env.local` for local development, and configure these
# same vars in Vercel (Project → Settings → Environment Variables) for prod.

# Supabase (public, safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (SERVER-ONLY, never expose to browser).
# Used only by lib/supabase/admin.ts in server-side code paths
# (audit log writes, system maintenance). NEVER reference this var from
# any file in app/(...)/... client components or from lib/supabase/client.ts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider (server-only). The /api/ai/* routes use this on the server.
# Use whichever provider you've selected for the pilot. At least one is required
# for live AI responses; otherwise the routes fall back to deterministic mock replies.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Storage bucket name for documents. Must match the bucket created in Supabase
# Storage (see SUPABASE_SETUP.md). Defaults to "snap-documents".
SUPABASE_STORAGE_BUCKET=snap-documents

# Public app URL — used for Supabase Auth email confirmation redirect.
NEXT_PUBLIC_APP_URL=http://localhost:3000
