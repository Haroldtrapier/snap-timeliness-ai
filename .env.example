# Supabase — OPTIONAL.
# When set, the app uses real Supabase Auth + Postgres. When unset, it falls
# back to the built-in demo session so the site still runs. Add these in Vercel
# (Project → Settings → Environment Variables) to enable real auth in production.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
