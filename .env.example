# Supabase — OPTIONAL.
# When set, the app uses real Supabase Auth + Postgres. When unset, it falls
# back to the built-in demo session so the site still runs. Add these in Vercel
# (Project → Settings → Environment Variables) to enable real auth in production.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic — OPTIONAL. Enables the AI notice-explainer (plain-language
# explanations of SNAP notices). When unset, notices are saved without an
# AI explanation. Add in Vercel to enable in production.
ANTHROPIC_API_KEY=

# Reminders cron (OPTIONAL). The daily job at /api/cron/reminders needs a
# service-role key to read deadlines across users (bypasses RLS — server-only).
# CRON_SECRET protects the endpoint; Vercel Cron sends it automatically.
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Email delivery for reminders (OPTIONAL). When both are set, the reminders
# cron sends real email via Resend (https://resend.com) and marks a reminder
# delivered only on success. When unset, reminders are recorded in-app only.
# REMINDERS_FROM_EMAIL must be a verified Resend sender, e.g. "SNAP AI <reminders@yourdomain.gov>".
RESEND_API_KEY=
REMINDERS_FROM_EMAIL=
