# SNAP AI — environment variables

# Supabase (public, safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (SERVER-ONLY, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider (server-only). The /api/ai/* routes use this on the server.
# Use whichever provider you've selected for the pilot.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Toggle mock mode (true => use in-memory mock data, false => use Supabase)
NEXT_PUBLIC_USE_MOCK_DATA=true
