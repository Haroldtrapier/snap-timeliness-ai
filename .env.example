# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/snap_ai"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="8h"

# Server
PORT=3001
NODE_ENV=development

# Anthropic AI
ANTHROPIC_API_KEY="your-anthropic-api-key"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# Frontend (used by Vite)
VITE_API_URL=http://localhost:3001
